# .env file

# ===== Image / Container Build =====
ZDM_USER="zdmuser"
ZDM_GROUP="zdm"
HOME_DIR="/home/zdmuser"
CONTAINER_NAME="zeus"
IMAGE_NAME="zeus:latest"
VOLUME_NAME="zdm_volume"
CONTAINER_HOSTNAME="zdm"

# Path inside the container where the ZDM kit zip is mounted at runtime
ZDM_KIT_MOUNT=/mnt/zdm/zdm.zip

# Provide ZDM_KIT_PATH when running ./run.sh the first time so the installer can unpack
# the kit into the persistent /u01 volume. Example:
# ZDM_KIT_PATH=/absolute/path/to/zdm.zip ./run.sh

# ===== ZDM Runtime Paths =====
ZDM_HOME="/u01/app/zdmhome"
ZDM_BASE="/u01/app/zdmbase"
ZDM_INSTALL_LOG="/u01/log"   # install/startup logs for ZDM

# ===== ZEUS Runtime Paths =====
ZEUS_DATA="/u01/data"
ZEUS_BASE="/u01/data/zeus"
